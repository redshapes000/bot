<!DOCTYPE html>
<html>
<head>
    <title>Dashboard</title>

    <style>
        body {
            margin: 0;
            font-family: Arial;
            background: #f4fff4;
            color: #111;
        }

        .header {
            background: #32cd32;
            color: white;
            padding: 20px;
            font-size: 20px;
        }

        .stats {
            display: flex;
            justify-content: center;
            margin-top: 20px;
            gap: 20px;
        }

        .box {
            background: white;
            padding: 20px;
            border-radius: 10px;
            width: 150px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
            text-align: center;
        }

        .servers {
            margin-top: 40px;
            text-align: center;
        }

        a.server {
            display: block;
            margin: 10px auto;
            width: 300px;
            padding: 10px;
            background: white;
            border-left: 5px solid #32cd32;
            text-decoration: none;
            color: black;
            border-radius: 6px;
        }

        a.server:hover {
            background: #eaffea;
        }
    </style>
</head>

<body>

<div class="header">
    👋 Welcome, <%= user.username %>
</div>

<div class="stats">
    <div class="box">
        <h3><%= stats.servers %></h3>
        <p>Servers</p>
    </div>

    <div class="box">
        <h3><%= stats.users %></h3>
        <p>Users</p>
    </div>

    <div class="box">
        <h3><%= stats.ping %>ms</h3>
        <p>Ping</p>
    </div>
</div>

<div class="servers">
    <h2>Your Servers</h2>

    <% guilds.forEach(g => { %>
        <a class="server" href="/server/<%= g.id %>">
            <%= g.name %>
        </a>
    <% }) %>

</div>

</body>
</html>