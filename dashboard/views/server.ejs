<!DOCTYPE html>
<html>
<head>
    <title>Server Settings</title>

    <style>
        body {
            font-family: Arial;
            background: #f4fff4;
            margin: 0;
        }

        .header {
            background: #32cd32;
            color: white;
            padding: 20px;
        }

        .container {
            max-width: 500px;
            margin: 40px auto;
            background: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }

        input[type="text"] {
            width: 100%;
            padding: 10px;
            margin-top: 10px;
            border: 1px solid #ccc;
            border-radius: 6px;
        }

        button {
            margin-top: 20px;
            padding: 10px;
            width: 100%;
            background: #32cd32;
            border: none;
            color: white;
            border-radius: 6px;
            cursor: pointer;
        }

        button:hover {
            background: #28a428;
        }
    </style>
</head>

<body>

<div class="header">
    ⚙️ Server Settings
</div>

<div class="container">

<form method="POST">

    <label>Quarantine Role</label>
    <input type="text" name="quarantineRole"
        value="<%= settings.quarantineRole || '' %>">

    <label>
        <input type="checkbox" name="antiRaid"
        <%= settings.antiRaid ? "checked" : "" %>>
        Anti-Raid System
    </label>

    <button type="submit">Save Settings</button>

</form>

</div>

</body>
</html>